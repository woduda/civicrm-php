includes:
    - vendor/phpstan/phpstan-strict-rules/rules.neon

parameters:
    level: max
    paths:
        - src
        - tests
    treatPhpDocTypesAsCertain: false
    # Load the backwards-compatibility alias so PHPStan's reflection resolves the
    # legacy Woduda\CiviCRM\Exception\ApiException name to ApiErrorException.
    bootstrapFiles:
        - src/Exception/ApiException.php
