{
    "name": "woduda/civicrm-api-client",
    "description": "PSR-18 compatible client for CiviCRM REST APIv4",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Wojciech Duda",
            "email": "wo.duda@gmail.com"
        }
    ],
    "require": {
        "php": ">=8.3",
        "psr/http-client": "^1.0",
        "psr/http-factory": "^1.1",
        "psr/http-message": "^2.0",
        "psr/log": "^3.0",
        "php-http/discovery": "^1.20"
    },
    "require-dev": {
        "guzzlehttp/guzzle": "^7.11",
        "laravel/pint": "^1.18",
        "nyholm/psr7": "^1.8",
        "pestphp/pest": "^3.0",
        "php-http/mock-client": "^1.6",
        "phpstan/phpstan": "^2.0",
        "phpstan/phpstan-strict-rules": "^2.0",
        "rector/rector": "^2.0"
    },
    "suggest": {
        "guzzlehttp/guzzle": "Guzzle PSR-18 HTTP client",
        "symfony/http-client": "Symfony PSR-18 HTTP client"
    },
    "autoload": {
        "psr-4": {
            "Woduda\\CiviCRM\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Woduda\\CiviCRM\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        }
    },
    "scripts": {
        "cs":        "pint",
        "cs:check":  "pint --test",
        "phpstan":   "phpstan analyse --memory-limit=512M",
        "test":      "pest --coverage --min=90",
        "mutate":    "pest --mutate --everything --min=80",
        "rector":    "rector process --dry-run",
        "smoke":     "php bin/smoke-test.php",
        "qa":        ["@cs:check", "@phpstan", "@rector", "@test", "@mutate"]
    }
}
